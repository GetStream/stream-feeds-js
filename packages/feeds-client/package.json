{
  "name": "@stream-io/feeds-client",
  "version": "1.6.0",
  "packageManager": "yarn@3.2.4",
  "main": "./dist/cjs/index.js",
  "module": "./dist/es/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "react-native": {
        "import": "./dist/es/index.mjs",
        "require": "./dist/cjs/index.js"
      },
      "import": "./dist/es/index.mjs",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    },
    "./react-bindings": {
      "types": "./dist/types/bindings/react/index.d.ts",
      "react-native": {
        "import": "./dist/es/react-bindings.mjs",
        "require": "./dist/cjs/react-bindings.js"
      },
      "import": "./dist/es/react-bindings.mjs",
      "require": "./dist/cjs/react-bindings.js",
      "default": "./dist/cjs/react-bindings.js"
    }
  },
  "license": "See license in LICENSE",
  "scripts": {
    "clean": "rimraf dist",
    "start": "yarn clean; concurrently 'vite build --watch' 'tsc -p tsconfig.lib.json --watch'",
    "build": "yarn clean; concurrently 'vite build' 'tsc -p tsconfig.lib.json'",
    "test": "vitest",
    "test:unit": "vitest --exclude '__integration-tests__/**'",
    "test-ci": "vitest --exclude '__integration-tests__/docs-snippets/**' --coverage",
    "test-docs-snippets": "vitest __integration-tests__/docs-snippets/**"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "react-bindings.js",
    "react-bindings.mjs",
    "react-bindings.d.ts",
    "package.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@stream-io/filter": "^1.0.1",
    "@stream-io/logger": "^2.0.0",
    "@stream-io/state-store": "^1.1.6",
    "axios": "^1.13.6"
  },
  "devDependencies": {
    "@stream-io/node-sdk": "catalog:",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "catalog:",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "happy-dom": "^20.8.3",
    "human-id": "^4.1.3",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vite": "^8",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": "^17 || ^18 || ^19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
